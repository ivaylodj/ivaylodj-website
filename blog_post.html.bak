	<!-- Minimal overrides that do NOT fight theme.css -->
	<style>
	.cherga_blog_post_content { line-height: 1.7; }
	/* Full-width layout for blog_image template (no sidebar) */
	.cherga_no_sidebar .cherga_content {
		width: 1170px;
		padding-right: 0;
	}
	.cherga_no_sidebar .cherga_sidebar {
		display: none !important;
	}
	/* "You may also like" related posts section */
	.cherga_featured_posts_heading {
		font-size: 16px;
		font-weight: 700;
		text-transform: uppercase;
		color: #e8e9eb;
		margin: 40px 0 30px 0;
		letter-spacing: 0.5px;
	}
	.cherga_featured_posts {
		display: flex;
		gap: 30px;
		margin-bottom: 40px;
	}
	.cherga_featured_posts.cherga_items_2 .cherga_posts_item {
		flex: 1;
	}
	.cherga_posts_item {
		background: #2c2f33;
		border-radius: 4px;
		overflow: hidden;
	}
	.cherga_fimage_cont {
		width: 100%;
		height: 200px;
		overflow: hidden;
		background: #1a1d21;
	}
	.cherga_fimage_cont img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	.cherga_fimage_cont a {
		display: block;
		width: 100%;
		height: 100%;
	}
	.cherga_posts_item .cherga_post_meta {
		padding: 16px;
	}
	.cherga_posts_item .cherga_post_title {
		margin: 12px 16px 0 16px;
		font-size: 16px;
	}
	.cherga_posts_item .cherga_post_title a {
		color: #e8e9eb;
		text-decoration: none;
	}
	.cherga_posts_item .cherga_post_title a:hover {
		color: #b0b4b9;
	}
	.cherga_posts_item .cherga_excerpt {
		padding: 0 16px 16px 16px;
		font-size: 13px;
		color: #b0b4b9;
		line-height: 1.5;
	}
	/* Carousel display fixes */
	.cherga_pf_image {
		min-height: 400px;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.cherga_owlCarousel {
		display: flex;
		width: 100%;
	}
	.owl-stage {
		width: 100% !important;
		display: flex;
	}
	.owl-item {
		flex: 0 0 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.owl-item .item {
		width: 100%;
		height: auto;
		max-height: 600px;
	}
	.owl-item img {
		max-width: 100%;
		height: auto;
		display: block;
	}
	/* Widget Styles */
	.widget {
		margin-bottom: 32px;
	}
	.widget h6.widgettitle {
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
		color: #e8e9eb;
		margin-bottom: 16px;
		letter-spacing: 0.5px;
		border-bottom: 1px solid #3a3e43;
		padding-bottom: 12px;
		position: relative;
		padding-left: 16px;
	}
	.widget h6.widgettitle:before {
		content: '';
		display: inline-block;
		width: 10px;
		height: 10px;
		background: #f5a623;
		position: absolute;
		left: 0;
		top: 50%;
		transform: translateY(-50%);
	}
	.widget ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.widget ul li {
		padding: 10px 0;
		border-bottom: 1px solid #3a3e43;
		line-height: 1.4;
	}
	.widget ul li:last-child {
		border-bottom: none;
	}
	.widget ul li a {
		color: #b0b4b9;
		text-decoration: none;
		font-size: 14px;
	}
	.widget ul li a:hover {
		color: #e8e9eb;
	}
	/* Tag Cloud */
	.widget_tag_cloud .tagcloud {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}
	.widget_tag_cloud .tagcloud a {
		display: inline-block;
		padding: 6px 12px;
		background: #3a3e43;
		color: #b0b4b9 !important;
		text-decoration: none !important;
		border-radius: 3px;
		font-size: 13px;
		transition: all 0.2s;
	}
	.widget_tag_cloud .tagcloud a:hover {
		background: #454950;
		color: #e8e9eb !important;
	}
	/* Featured Posts in Sidebar */
	.cherga_featured_posts_list {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.cherga_featured_post_item {
		display: flex;
		gap: 12px;
		padding: 12px 0;
		border-bottom: 1px solid #3a3e43;
		align-items: flex-start;
	}
	.cherga_featured_post_item:last-child {
		border-bottom: none;
	}
	.cherga_featured_post_image {
		width: 60px;
		height: 60px;
		min-width: 60px;
		object-fit: cover;
		border-radius: 3px;
		display: block;
	}
	.cherga_featured_post_content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.cherga_featured_post_title {
		font-size: 14px;
		font-weight: 600;
		color: #e8e9eb;
		text-decoration: none;
		display: block;
		margin: 0;
		line-height: 1.3;
	}
	.cherga_featured_post_title:hover {
		color: #b0b4b9;
	}
	.cherga_featured_post_meta {
		font-size: 12px;
		color: #9a9ea3;
		margin: 0;
	}
	/* Text Widget */
	.widget_text .widgettitle {
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
		color: #e8e9eb;
		margin-bottom: 12px;
		letter-spacing: 0.5px;
		border-bottom: 1px solid #3a3e43;
		padding-bottom: 12px;
	}
	.widget_text p {
		font-size: 13px;
		line-height: 1.6;
		color: #b0b4b9;
		margin-bottom: 12px;
	}
	.widget_text p:last-child {
		margin-bottom: 0;
	}
	.widget_text img {
		width: 100%;
		height: auto;
		border-radius: 4px;
	}
	/* Flickr Button */
	.cherga_flickr_follow_btn {
		display: inline-block;
		padding: 10px 16px;
		background: #3a3e43;
		color: #b0b4b9 !important;
		text-decoration: none !important;
		border-radius: 3px;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: all 0.2s;
	}
	.cherga_flickr_follow_btn:hover {
		background: #454950;
		color: #e8e9eb !important;
	}
	.cherga_flickr_follow_btn i {
		margin-right: 6px;
	}
	/* Footer Styles */
	.cherga_footer_inner {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 40px;
		padding: 60px 0;
		border-bottom: 1px solid #3a3e43;
	}
	.cherga_footer_section {
		display: flex;
		flex-direction: column;
	}
	.cherga_footer_logo_section {
		grid-column: 1;
	}
	.cherga_footer_heading {
		font-size: 14px;
		font-weight: 700;
		text-transform: uppercase;
		color: #e8e9eb;
		margin-bottom: 16px;
		letter-spacing: 0.5px;
	}
	.cherga_footer_section p {
		font-size: 13px;
		line-height: 1.6;
		color: #b0b4b9;
		margin-bottom: 12px;
	}
	.cherga_footer_section p:last-child {
		margin-bottom: 0;
	}
	.cherga_footer_section a {
		color: #b0b4b9;
		text-decoration: none;
		transition: color 0.2s;
	}
	.cherga_footer_section a:hover {
		color: #e8e9eb;
	}
	.cherga_footer_section i {
		margin-right: 6px;
	}
	/* Footer Featured Posts */
	.cherga_footer_featured_posts {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.cherga_footer_featured_posts li {
		margin-bottom: 16px;
		padding-bottom: 16px;
		border-bottom: 1px solid #3a3e43;
	}
	.cherga_footer_featured_posts li:last-child {
		border-bottom: none;
		margin-bottom: 0;
		padding-bottom: 0;
	}
	.cherga_footer_featured_posts a {
		display: block;
		font-size: 13px;
		font-weight: 600;
		color: #e8e9eb;
		text-decoration: none;
		margin-bottom: 4px;
	}
	.cherga_footer_featured_posts a:hover {
		color: #b0b4b9;
	}
	.cherga_footer_featured_posts .cherga_post_date {
		font-size: 12px;
		color: #9a9ea3;
	}
	/* Footer Links */
	.cherga_footer_links {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.cherga_footer_links li {
		margin-bottom: 8px;
	}
	.cherga_footer_links li:last-child {
		margin-bottom: 0;
	}
	.cherga_footer_links a {
		font-size: 13px;
		color: #b0b4b9;
		text-decoration: none;
	}
	.cherga_footer_links a:hover {
		color: #e8e9eb;
	}
	/* Footer Bottom */
	.cherga_footer_bottom {
		grid-column: 1 / -1;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 20px;
		border-top: 1px solid #3a3e43;
	}
	.cherga_copyright {
		font-size: 12px;
		color: #9a9ea3;
	}
	.cherga_footer_go_to_top {
		display: inline-block;
		padding: 8px 16px;
		background: #3a3e43;
		color: #b0b4b9 !important;
		text-decoration: none !important;
		border-radius: 3px;
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		transition: all 0.2s;
	}
	.cherga_footer_go_to_top:hover {
		background: #454950;
		color: #e8e9eb !important;
	}
	.cherga_footer_go_to_top i {
		margin-right: 4px;
	}
	</style>
</head>

