{
  "name": "ivaylodj-website",
  "version": "1.0.0",
  "description": "Photography portfolio website with blog system",
  "main": "js/theme.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest _tests/unit",
    "test:integration": "jest _tests/integration",
    "test:regression": "jest _tests/regression",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "pre-commit": "npm run test:unit && npm run test:integration && npm run test:regression"
  },
  "keywords": [
    "photography",
    "portfolio",
    "blog",
    "website"
  ],
  "author": "Ivaylo Djounov",
  "license": "All Rights Reserved",
  "devDependencies": {
    "@testing-library/dom": "^9.3.4",
    "cypress": "^13.6.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
